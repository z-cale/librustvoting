{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch zallyd start",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "sdk/cmd/zallyd/main.go",
            "buildFlags": "-tags=halo2,redpallas",
            "dlvFlags": ["--check-go-version=false"],
            "args": [
                "start",
                "--home",
                "${env:HOME}/.zallyd"
            ]
        },
        {
            // Note: zallyd must already be running with Delve.
            // Example:
            //   dlv exec ./zallyd --headless --listen=:2345 --api-version=2 -- start --home ~/.zallyd
            "name": "Attach to running zallyd process",
            "type": "go",
            "request": "attach",
            "mode": "remote",
            "port": 2345,
            "host": "127.0.0.1",
            "apiVersion": 1,
            "showLog": true
        }
    ]
}
