# Required — set in Vercel project settings, not here.
#
# Slack bot OAuth token (xoxb-...). Required scopes: chat:write.
SLACK_BOT_TOKEN=
# Slack channel ID for #ext-zcash-contrib-notif.
SLACK_NOTIFIER_CHANNEL_ID=
# GitHub personal access token (public_repo scope for rate-limit headroom).
GITHUB_TOKEN=
# Vercel REST API token with Edge Config write access.
VERCEL_API_TOKEN=
# Edge Config store ID (ecfg_...).
EDGE_CONFIG_ID=

# Optional — comma-separated Slack user IDs to @-mention on notifications.
# SLACK_MENTION_IDS=U12345,U67890

# Optional — override defaults.
# TRACKED_GITHUB_AUTHORS=czarcas7ic,p0mvn,greg0x,ValarDragon
# TRACKED_REPO_OWNERS=ZcashFoundation,zcash,zodl-inc

# Set to "true" to log without posting to Slack.
# NOTIFIER_DRY_RUN=false
