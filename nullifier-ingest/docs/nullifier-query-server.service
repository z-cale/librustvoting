[Unit]
Description=Nullifier PIR server (nf-server)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/nullifier-ingest
ExecStart=/opt/nullifier-ingest/nf-server serve \
    --pir-data-dir /opt/nullifier-ingest/pir-data \
    --data-dir /opt/nullifier-ingest \
    --port 3000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
