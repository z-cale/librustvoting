# Reverse-proxy the Zally chain REST API with automatic HTTPS.
#
# Uses sslip.io for DNS so a bare IP gets a valid Let's Encrypt certificate.
# Replace the hostname if you have a real domain.
#
# Install:  apt install caddy
# Deploy:   sudo cp deploy/Caddyfile /etc/caddy/Caddyfile && sudo systemctl restart caddy
#   — or —  make caddy   (from the sdk directory)

46-101-255-48.sslip.io {
	# No CORS headers here — the nullifier query-server sets its own via
	# CorsLayer (same reason we skip them for zallyd; duplicates cause browsers
	# to reject the response with "multiple values" errors).
	handle_path /nullifier/* {
		reverse_proxy localhost:3000
	}

	handle_path /releases/* {
		root * /opt/zally-chain/releases
		file_server
	}

	reverse_proxy localhost:1418
}
