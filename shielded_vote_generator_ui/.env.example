# Zally chain REST API URL.
# Used as the default chain URL in the UI and as the Vite dev-server proxy target.
# Default: http://localhost:1318
VITE_CHAIN_URL=http://localhost:1318

# Lightwalletd gRPC-web endpoint for Zcash mainnet.
# Used as the default RPC endpoint for chain height / note scanning.
# Default: https://us.zec.stardust.rest (first entry in the built-in endpoint list)
VITE_LIGHTWALLETD_RPC=https://us.zec.stardust.rest
